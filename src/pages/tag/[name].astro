---
import { getTags, getAllPosts } from '../../lib/wordpress';
import { mapPost } from '../../lib/mappers';
import type { Post } from '../../lib/mappers';
import Layout from '../../layouts/Layout.astro';
import PostGrid from '../../components/PostGrid.astro';

function isAsciiSlug(slug: string): boolean {
  return /^[\w-]+$/.test(slug);
}

export async function getStaticPaths() {
  try {
    const wpTags = await getTags();
    const validTags = wpTags.filter((t) => isAsciiSlug(t.slug));
    return validTags.map((tag) => ({
      params: { name: tag.slug },
      props: { tagName: tag.name, tagSlug: tag.slug },
    }));
  } catch {
    return [];
  }
}

const { name } = Astro.params;
const tagName = Astro.props.tagName || name;

let posts: Post[] = [];
try {
  const wpPosts = await getAllPosts();
  const allMapped = wpPosts.map(mapPost);
  const displayName = Astro.props.tagName || name;
  posts = allMapped.filter((p) => p.tags.includes(displayName));
} catch {
  posts = [];
}
---

<Layout title={`标签: ${tagName}`}>
  <main class="main-layout" style="grid-template-columns: 1fr;">
    <section class="content-area" style="max-width: 1000px; margin: 0 auto; width: 100%;">
      <div class="content-header">
        <h2 class="content-title">
          <span style="margin-right: 8px;">🏷️</span>
          {tagName}
          <span style="font-size: 14px; font-weight: 400; color: var(--fg-muted); margin-left: 8px;">{posts.length} 篇文章</span>
        </h2>
      </div>
      {posts.length > 0 ? (
        <PostGrid posts={posts} />
      ) : (
        <div class="sidebar-card" style="padding: 60px 40px; text-align: center;">
          <p style="color: var(--fg-secondary);">该标签暂无文章</p>
          <a href="/" style="display: inline-block; margin-top: 16px; color: var(--accent); font-size: 13px;">返回首页</a>
        </div>
      )}
    </section>
  </main>
</Layout>
