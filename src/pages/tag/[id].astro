---
import { getTags, getPostsByTag } from '../../lib/wordpress';
import { mapPost } from '../../lib/mappers';
import { nameToTagId } from '../../lib/route-ids';
import type { Post } from '../../lib/mappers';
import Layout from '../../layouts/Layout.astro';
import PostGrid from '../../components/PostGrid.astro';
import { wpConfig } from '../../config';
import { siteConfig } from '../../site.config';

const { id } = Astro.params;

let tagName = '';
let posts: Post[] = [];

try {
  const wpTags = await getTags();

  const found = wpTags.find((t) => nameToTagId(t.name) === id);
  if (found) {
    tagName = found.name;
    const wpPosts = await getPostsByTag(found.id, 1, wpConfig.perPage);
    posts = wpPosts.map(mapPost);
  }
} catch {
  posts = [];
}

if (!tagName) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
---

<Layout title={`标签: ${tagName}`} favicon={siteConfig.site.favicon} icon={siteConfig.site.favicon} logo={siteConfig.site.logo.light}>
  <main class="main-layout" style="grid-template-columns: 1fr;">
    <section class="content-area" style="max-width: 1000px; margin: 0 auto; width: 100%;">
      <div class="content-header">
        <h2 class="content-title">
          <span style="margin-right: 8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -2px;"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </span>
          {tagName}
          <span style="font-size: 14px; font-weight: 400; color: var(--fg-muted); margin-left: 8px;">{posts.length} 篇文章</span>
        </h2>
      </div>
      {posts.length > 0 ? (
        <PostGrid posts={posts} />
      ) : (
        <div class="sidebar-card" style="padding: 60px 40px; text-align: center;">
          <p style="color: var(--fg-secondary);">该标签暂无文章</p>
          <a href="/" style="display: inline-block; margin-top: 16px; color: var(--accent); font-size: 13px;">返回首页</a>
        </div>
      )}
    </section>
  </main>
</Layout>