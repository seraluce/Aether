---
export const prerender = true;

import { getPostById, getAllPosts, getCategories, getPosts } from "../../lib/wordpress";
import type { WPPost } from "../../lib/wordpress";
import { mapCategory, mapPost } from "../../lib/mappers";
import Layout from "../../layouts/Layout.astro";
import ArticleActions from "../../components/ArticleActions.astro";
import ArticleSidebar from "../../components/ArticleSidebar.astro";
import { siteConfig } from "../../site.config";
import { wpConfig } from "../../config";

export async function getStaticPaths() {
  try {
    const posts = await getAllPosts();
    return posts.map((post) => ({
      params: { id: String(post.id) },
    }));
  } catch {
    return [];
  }
}

const { id } = Astro.params;
const siteLogo = siteConfig.site.logo.light;
const siteFavicon = siteConfig.site.favicon;
const siteIcon = siteConfig.site.favicon;

let post: WPPost | null = null;
let recentPosts: WPPost[] = [];
let wpCategories: Array<{
  name: string;
  slug: string;
  count: number;
  icon: string;
}> = [];

try {
  const [wpPosts, wpCats] = await Promise.all([
    getPosts(1, Math.min(wpConfig.perPage, 20)),
    getCategories(),
  ]);
  recentPosts = wpPosts;
  wpCategories = wpCats.map(mapCategory);
} catch {
  // fallback: empty data
}

if (id) {
  try {
    post = await getPostById(Number(id));
  } catch {
    post = null;
  }
}

if (!post) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

function stripHtml(html: string | undefined | null): string {
  if (!html) return "";
  return html.replace(/<[^>]*>/g, "").trim();
}

const pageTitle = stripHtml(post.title?.rendered);
const pageDesc = stripHtml(post.excerpt?.rendered).slice(0, 160);
const pageImage =
  post?._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
  "/images/og-image.png";
const authorName = post?._embedded?.author?.[0]?.name || "";
const categoryName = post?._embedded?.["wp:term"]?.[0]?.[0]?.name || "";
const categorySlug = post?._embedded?.["wp:term"]?.[0]?.[0]?.slug || "";
const tagNames =
  post?._embedded?.["wp:term"]?.[1]?.map((t: { name: string }) => t.name) || [];
const tagSlugs =
  post?._embedded?.["wp:term"]?.[1]?.map((t: { slug: string }) => t.slug) || [];

const pageUrl = `/article/${id}`;

const relatedPosts = recentPosts
  .filter((p: WPPost) => String(p.id) !== id)
  .slice(0, 4)
  .map((p: WPPost) => ({
    id: p.id,
    title: stripHtml(p.title?.rendered),
    image:
      p._embedded?.["wp:featuredmedia"]?.[0]?.source_url ||
      `https://picsum.photos/seed/${p.id}/120/90`,
  }));
---

<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/javascript.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/python.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/css.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/xml.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/bash.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/json.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/typescript.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/java.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/php.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/sql.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/go.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/rust.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/cpp.min.js" defer></script>

<Layout
  title={pageTitle}
  description={pageDesc}
  image={pageImage}
  url={pageUrl}
  type="article"
  publishedTime={post?.date}
  author={authorName}
  category={categoryName}
  tags={tagNames}
  categories={wpCategories}
  favicon={siteFavicon}
  icon={siteFavicon}
  logo={siteLogo}
>
  <div class="article-layout">
    <ArticleActions postId={Number(id)} pageUrl={pageUrl} title={pageTitle} />

    <div class="article-main">
      <article>
        <header class="article-header">
          <!-- {
            pageImage && pageImage.startsWith("http") && (
              <img src={pageImage} alt={pageTitle} class="article-cover" />
            )
          } -->
          <h1>{pageTitle}</h1>
          <div class="article-meta">
            <!-- {authorName && <span>{authorName}</span>}
            {authorName && <span class="sep">|</span>} -->
            <span
              >{
                new Date(post.date).toLocaleDateString("zh-CN", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              }</span
            >
            {
              categoryName && categorySlug && (
                <>
                  <span class="sep">|</span>
                  <a href={`/topic/${categorySlug}`} class="accent">
                    {categoryName}
                  </a>
                </>
              )
            }
            {
              categoryName && !categorySlug && (
                <>
                  <span class="sep">|</span>
                  <span class="accent">{categoryName}</span>
                </>
              )
            }
          </div>
          {
            tagNames.length > 0 && (
              <div class="article-tags">
                {/* 标签图标 */}
                <svg
                  class="tag-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2z" />
                  <path d="M7 7h.01" />
                </svg>

                {tagNames.map((tag: string, i: number) => {
                  const slug = tagSlugs[i] || tag;
                  return <a href={`/tag/${slug}`}>{tag}</a>;
                })}
              </div>
            )
          }
        </header>
        <div class="article-content" set:html={post.content.rendered} />
        <div class="article-footer">
          <button id="goBack" class="goback">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg
            >
            返回上一页
          </button>
        </div>
      </article>
    </div>

    <aside class="article-sidebar">
      <ArticleSidebar relatedPosts={relatedPosts} />
    </aside>
  </div>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var content = document.querySelector(".article-content");
    if (!content) return;

    var imgs = content.querySelectorAll<HTMLImageElement>("img");
    imgs.forEach(function (img) {
      var src = img.getAttribute("src");
      if (src) {
        img.setAttribute("data-src", src);
        img.removeAttribute("src");
        img.style.minHeight = "120px";
        img.style.background = "var(--bg-tertiary)";
      }
    });

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var img = entry.target as HTMLImageElement;
            var dataSrc = img.getAttribute("data-src");
            if (dataSrc) {
              img.setAttribute("src", dataSrc);
              img.removeAttribute("data-src");
              img.addEventListener("load", function () {
                img.classList.add("img-loaded");
                img.style.minHeight = "";
                img.style.background = "";
              });
              img.addEventListener("error", function () {
                img.classList.add("img-loaded");
                img.style.minHeight = "";
                img.style.background = "";
              });
            }
            observer.unobserve(img);
          }
        });
      },
      { rootMargin: "300px" },
    );

    imgs.forEach(function (img) {
      observer.observe(img);
    });
    document.getElementById("goBack").addEventListener("click", () => {
      window.history.back();
    });

    // 代码块：高亮 + 行号 + 语言标识 + 复制按钮
    function processCodeBlocks() {
    var pres = content.querySelectorAll("pre");
    pres.forEach(function (pre) {
      var code = pre.querySelector("code");
      if (!code) return;

      // 检测语言
      var lang = "";
      var codeClass = code.className || "";
      var langMatch = codeClass.match(/language-(\w+)/i) || codeClass.match(/lang-(\w+)/i);
      if (langMatch) {
        lang = langMatch[1].toLowerCase();
      }

      // 获取纯文本
      var rawText = code.textContent || "";

      // highlight.js 高亮
      var hljs = (window as any).hljs;
      if (typeof hljs !== "undefined") {
        if (lang) {
          try { hljs.highlightElement(code); } catch(e) {}
        } else {
          try {
            var result = hljs.highlightAuto(rawText);
            lang = result.language || "";
            code.innerHTML = result.value;
          } catch(e) {}
        }
      }

      // 语言显示名映射
      var langNames = {
        js: "JavaScript", javascript: "JavaScript", ts: "TypeScript", typescript: "TypeScript",
        py: "Python", python: "Python", html: "HTML", xml: "XML", css: "CSS",
        json: "JSON", bash: "Bash", shell: "Shell", sh: "Shell",
        java: "Java", php: "PHP", sql: "SQL", go: "Go", golang: "Go",
        rust: "Rust", cpp: "C++", c: "C", cs: "C#", ruby: "Ruby",
        swift: "Swift", kotlin: "Kotlin", yaml: "YAML", toml: "TOML",
        markdown: "Markdown", md: "Markdown", jsx: "JSX", tsx: "TSX",
        vue: "Vue", svelte: "Svelte", dockerfile: "Dockerfile",
      };
      var displayName = lang ? (langNames[lang] || lang.charAt(0).toUpperCase() + lang.slice(1)) : "Code";

      // 构建头部栏
      var header = document.createElement("div");
      header.className = "code-header";
      header.innerHTML =
        '<span class="code-lang">' + displayName + '</span>' +
        '<button class="code-copy-btn">' +
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>' +
          '<span>复制</span>' +
        '</button>';
      pre.insertBefore(header, code);

      // 添加行号
      var lines = rawText.split("\n");
      if (lines[lines.length - 1] === "") lines.pop();
      var lineNums = lines.map(function(_, i) {
        return '<span class="line-num">' + (i + 1) + '</span>';
      }).join("\n");

      // 给每行添加行号
      var codeLines = code.innerHTML.split("\n");
      if (codeLines[codeLines.length - 1] === "") codeLines.pop();
      var numberedHTML = codeLines.map(function(line, i) {
        return '<span class="line-num">' + (i + 1) + '</span>' + line;
      }).join("\n");
      code.innerHTML = numberedHTML;

      // 复制按钮事件
      var copyBtn = header.querySelector(".code-copy-btn");
      copyBtn.addEventListener("click", function () {
        navigator.clipboard.writeText(rawText).then(function () {
          copyBtn.innerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>' +
            '<span>已复制</span>';
          copyBtn.classList.add("copied");
          setTimeout(function () {
            copyBtn.innerHTML =
              '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>' +
              '<span>复制</span>';
            copyBtn.classList.remove("copied");
          }, 2000);
        });
      });
    });
    } // end processCodeBlocks

    // 等待 highlight.js 加载完成后处理代码块
    function waitForHljs() {
      if (typeof (window as any).hljs !== "undefined") {
        processCodeBlocks();
      } else {
        setTimeout(waitForHljs, 100);
      }
    }
    waitForHljs();
  });
</script>
<style>
  .article-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px 8px;
  color: var(--text-secondary, #666);
  font-size: 14px;
}

.tag-icon {
  flex-shrink: 0;
  display: block;
  /* 颜色继承父级 */
  color: inherit;
  /* 垂直居中通过父级 align-items: center 实现 */
  /* 大小通过 width/height 控制 */
}

.article-tags a {
  color: inherit;
  text-decoration: none;
  transition: color 0.2s ease;
  line-height: 1.4;
}

.article-tags a:hover {
  color: var(--link-hover, #4A90D9);
  text-decoration: underline;
}

/* 如果标签之间需要分隔符，可以加上 */
