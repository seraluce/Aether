---
import Layout from '../layouts/Layout.astro';
import SidebarLeft from '../components/SidebarLeft.astro';
import SidebarRight from '../components/SidebarRight.astro';
import { siteConfig } from '../site.config';
import { fetchSiteData } from '../data/fetcher';
import { mockData } from '../data/mock';

const data = await fetchSiteData();
const siteData = data.error ? mockData : data;
const about = siteConfig.about;
const social = about.social || siteConfig.social;

function socialIcon(icon: string): string {
  const icons: Record<string, string> = {
    github: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>',
    twitter: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
    email: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>',
    wechat: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.11.24-.245 0-.06-.024-.12-.04-.178l-.325-1.233a.492.492 0 01.177-.554C23.028 18.485 24 16.82 24 14.98c0-3.21-2.931-5.837-7.062-6.122zM14.485 13.5c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"/></svg>',
  };
  return icons[icon] || icons['email'];
}
---

<Layout title="关于" url="/about" categories={siteData.categories}>
  <main class="main-layout">
    <aside class="sidebar-left">
      <SidebarLeft categories={siteData.categories} />
    </aside>
    <section class="content-area">
      <div class="about-page">
        <div class="about-header">
          <img src={about.avatar} alt={about.name} class="about-avatar" />
          <div class="about-info">
            <h1 class="about-name">{about.name}</h1>
            <p class="about-bio">{about.bio}</p>
          </div>
        </div>

        <div class="about-card">
          <h2 class="about-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            关于我
          </h2>
          <p class="about-desc">{about.description}</p>
        </div>

        <div class="about-card">
          <h2 class="about-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
            社交链接
          </h2>
          <div class="about-social">
            {social.map((s) => (
              <a href={s.url} target="_blank" rel="noopener" class="about-social-link">
                <span class="about-social-icon" set:html={socialIcon(s.icon)} />
                <span>{s.name}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="about-card">
          <h2 class="about-card-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            快速链接
          </h2>
          <div class="about-links">
            <a href="/">首页</a>
            <a href="/archive">文章归档</a>
            <a href="/tags">全部标签</a>
            <a href="/sitemap.xml">站点地图</a>
          </div>
        </div>
      </div>
    </section>
    <aside class="sidebar-right">
      <SidebarRight hotPosts={siteData.hotPosts} tags={siteData.tags} />
    </aside>
  </main>
</Layout>
