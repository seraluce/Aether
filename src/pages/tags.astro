---
import Layout from '../layouts/Layout.astro';
import { fetchSiteData } from '../data/fetcher';
import { mockData } from '../data/mock';

const data = await fetchSiteData();
const siteData = data.error ? mockData : data;
const tags = siteData.tags;
---

<Layout title="全部标签" url="/tags" categories={siteData.categories}>
  <main class="main-layout" style="grid-template-columns: 1fr;">
    <section class="content-area" style="max-width: 800px; margin: 0 auto; width: 100%;">
      <div class="content-header">
        <h2 class="content-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -3px; margin-right: 6px;">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
          </svg>
          全部标签
          <span style="font-size: 14px; font-weight: 400; color: var(--fg-muted); margin-left: 8px;">{tags.length} 个标签</span>
        </h2>
      </div>
      <div class="sidebar-card" style="padding: 24px;">
        <div class="tag-cloud tag-cloud-full">
          {tags.map((tag) => (
            <a href={`/tag/${tag}`}>{tag}</a>
          ))}
        </div>
        {tags.length === 0 && (
          <p style="color: var(--fg-muted); text-align: center; padding: 40px 0;">暂无标签</p>
        )}
      </div>
    </section>
  </main>
</Layout>
