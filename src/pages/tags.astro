---
import Layout from "../layouts/Layout.astro";
import SidebarLeft from "../components/SidebarLeft.astro";
import SidebarRight from "../components/SidebarRight.astro";
import { fetchSiteData } from "../data/fetcher";
import { mockData } from "../data/mock";
import { siteConfig } from "../site.config";
import { nameToTagId } from "../lib/route-ids";

const data = await fetchSiteData();
const siteData = data.error ? mockData : data;
const tags = [...siteData.tags].sort((a, b) => b.count - a.count);
const siteFavicon = siteConfig.site.favicon;
const siteLogo = siteConfig.site.logo.light;
---

<Layout 
title="全部标签" 
url="/tags" 
favicon={siteFavicon}
  icon={siteFavicon}
  logo={siteLogo}
categories={siteData.categories}>
  <main class="main-layout">
    <aside class="sidebar-left">
      <SidebarLeft categories={siteData.categories} />
    </aside>
    <section class="tags-area">
      <div class="content-header">
        <h2 class="content-title">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            style="vertical-align: -3px; margin-right: 6px;"
          >
            <path
              d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"
            ></path><line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          全部标签
          <span
            style="font-size: 14px; font-weight: 400; color: var(--fg-muted); margin-left: 8px;"
            >{tags.length} 个标签</span
          >
        </h2>
      </div>
      <div class="sidebar-card" style="padding: 24px;">
        <div class="tag-cloud tag-cloud-full">
          {tags.map((tag) => <a href={`/tag/${nameToTagId(tag.name)}`}>{tag.name}</a>)}
        </div>
        {
          tags.length === 0 && (
            <p style="color: var(--fg-muted); text-align: center; padding: 40px 0;">
              暂无标签
            </p>
          )
        }
      </div>
    </section>
    <aside class="sidebar-right">
      <SidebarRight hotPosts={siteData.hotPosts} tags={siteData.tags} />
    </aside>
  </main>
</Layout>

<style>
  .tags-area{
    min-width: 0;
    padding: 0 20px;
    margin-top: 4px;
  }

  /* Tags full page */
.tag-cloud-full {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.tag-cloud-full a {
  padding: 6px 14px;
  border-radius: 6px;
  background: var(--bg-secondary);
  color: var(--fg-secondary);
  text-decoration: none;
  font-size: 13px;
  border: 1px solid var(--border);
  transition: all 0.15s;
}
.tag-cloud-full a:hover {
  border-color: var(--border-hover);
  color: var(--accent);
  background: var(--accent-bg);
}
</style>