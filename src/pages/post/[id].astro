---
import { getPostById, getPosts, getCategories } from '../../lib/wordpress';
import type { WPPost, WPCategory } from '../../lib/wordpress';
import { mapCategory } from '../../lib/mappers';
import Layout from '../../layouts/Layout.astro';
import ArticleActions from '../../components/ArticleActions.astro';
import ArticleSidebar from '../../components/ArticleSidebar.astro';

export async function getStaticPaths() {
  let posts: Array<{ params: { id: string }; props: { post: WPPost | null; allPosts: WPPost[]; categories: Array<{ name: string; slug: string; count: number; icon: string }> } }> = [];
  try {
    const [wpPosts, wpCategories] = await Promise.all([
      getPosts(1, 100),
      getCategories(),
    ]);
    const fullPosts = await Promise.all(
      wpPosts.map((p) => getPostById(p.id).catch(() => null))
    );
    const categories = wpCategories.map(mapCategory);
    posts = wpPosts.map((p, i) => ({
      params: { id: String(p.id) },
      props: { post: fullPosts[i], allPosts: wpPosts, categories },
    }));
  } catch {
    const { mockData } = await import('../../data/mock');
    posts = mockData.posts.map((p, i) => ({
      params: { id: String(i + 1) },
      props: { post: null, allPosts: [], categories: mockData.categories },
    }));
  }
  return posts;
}

const { id } = Astro.params;
const post = Astro.props.post;
const allPosts = Astro.props.allPosts;
const wpCategories = Astro.props.categories;

function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').trim();
}

const pageTitle = post ? stripHtml(post.title.rendered) : '文章';
const pageDesc = post ? stripHtml(post.excerpt.rendered).slice(0, 160) : '';
const pageImage = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url || '/images/og-image.png';
const authorName = post?._embedded?.author?.[0]?.name || '';
const categoryName = post?._embedded?.['wp:term']?.[0]?.[0]?.name || '';
const tagNames = post?._embedded?.['wp:term']?.[1]?.map((t: {name: string}) => t.name) || [];

const pageUrl = `/post/${id}`;

const relatedPosts = allPosts
  .filter((p: WPPost) => String(p.id) !== id)
  .slice(0, 4)
  .map((p: WPPost) => ({
    id: p.id,
    title: stripHtml(p.title.rendered),
    image: p._embedded?.['wp:featuredmedia']?.[0]?.source_url || `https://picsum.photos/seed/${p.id}/120/90`,
  }));
---

<Layout
  title={pageTitle}
  description={pageDesc}
  image={pageImage}
  url={pageUrl}
  type="article"
  publishedTime={post?.date}
  author={authorName}
  category={categoryName}
  tags={tagNames}
  categories={wpCategories}
>
  <div class="article-layout">
    <ArticleActions postId={Number(id)} pageUrl={pageUrl} title={pageTitle} />

    <div class="article-main">
      {post ? (
        <article>
          <header class="article-header">
            {pageImage && pageImage.startsWith('http') && (
              <img src={pageImage} alt={pageTitle} class="article-cover" />
            )}
            <h1>{pageTitle}</h1>
            <div class="article-meta">
              {authorName && <span>{authorName}</span>}
              {authorName && <span class="sep">|</span>}
              <span>{new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              {categoryName && (
                <>
                  <span class="sep">|</span>
                  <span class="accent">{categoryName}</span>
                </>
              )}
            </div>
            {tagNames.length > 0 && (
              <div class="article-tags">
                {tagNames.map((tag: string) => (
                  <span>{tag}</span>
                ))}
              </div>
            )}
          </header>
          <div class="article-content" set:html={post.content.rendered} />
          <div class="article-footer">
            <a href="/">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              返回首页
            </a>
          </div>
        </article>
      ) : (
        <div class="sidebar-card" style="padding: 60px 40px; text-align: center;">
          <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">文章未找到</h2>
          <p style="color: var(--fg-secondary);">请检查文章地址是否正确。</p>
          <a href="/" style="display: inline-block; margin-top: 20px; color: var(--accent); font-size: 13px; font-weight: 500;">返回首页</a>
        </div>
      )}
    </div>

    <aside class="article-sidebar">
      <ArticleSidebar relatedPosts={relatedPosts} />
    </aside>
  </div>
</Layout>
