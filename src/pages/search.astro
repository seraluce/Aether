---
import Layout from "../layouts/Layout.astro";
import { searchPosts } from "../lib/wordpress";
import { mapPost } from "../lib/mappers";
import { slugToTopicId, postToArticleId } from "../lib/route-ids";
import { siteConfig } from "../site.config";
import { fetchSiteData } from "../data/fetcher";
import { mockData } from "../data/mock";

const query = Astro.url.searchParams.get("q") || "";
const siteFavicon = siteConfig.site.favicon;
const siteLogo = siteConfig.site.logo.light;
const siteIcon = siteConfig.site.logo.light;

const data = await fetchSiteData();
const siteData = data.error ? mockData : data;

let posts: import("../lib/mappers").Post[] = [];
if (query) {
  try {
    const wpPosts = await searchPosts(query);
    posts = wpPosts.map(mapPost);
  } catch {
    posts = [];
  }
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}/${d.getMonth() + 1}/${d.getDate()}`;
}

function formatViews(n: number): string {
  return n >= 10000 ? (n / 10000).toFixed(1) + "万" : n.toString();
}
---

<Layout
  title={query ? `搜索: ${query}` : "搜索"}
  favicon={siteFavicon}
  icon={siteIcon}
  logo={siteLogo}
  categories={siteData.categories}
>
  <main class="main-layout search-page-layout">
    <section class="search-content">
      <!-- 搜索框 -->
      <div class="search-bar-wrapper">
        <form class="search-bar" action="/search" method="get">
          <svg class="search-bar-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            type="text"
            name="q"
            class="search-bar-input"
            placeholder="搜索文章..."
            value={query}
            autocomplete="off"
          />
          {query && (
            <a href="/search" class="search-bar-clear" title="清除搜索">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </a>
          )}
          <button type="submit" class="search-bar-btn">搜索</button>
        </form>
      </div>

      <!-- 搜索结果头部 -->
      {query && (
        <div class="search-result-header">
          <span class="search-result-count">
            找到 <strong>{posts.length}</strong> 篇与「<span class="search-query-hl">{query}</span>」相关的文章
          </span>
        </div>
      )}

      <!-- 搜索结果列表 -->
      {posts.length > 0 ? (
        <div class="search-result-list">
          {posts.map((post) => (
            <article class="search-result-item">
              {post.image && (
                <a href={`/article/${postToArticleId(post.id)}`} class="search-result-img">
                  <img src={post.image} alt={post.title} loading="lazy" />
                </a>
              )}
              <div class="search-result-info">
                <h3 class="search-result-title">
                  <a href={`/article/${postToArticleId(post.id)}`}>{post.title}</a>
                </h3>
                <p class="search-result-excerpt">{post.excerpt}</p>
                <div class="search-result-meta">
                  <a href={`/topic/${slugToTopicId(post.categorySlug)}`} class="search-result-cat">{post.category}</a>
                  <span class="search-result-date">{formatDate(post.date)}</span>
                  <span class="search-result-views">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                    {formatViews(post.views)}
                  </span>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : query ? (
        <div class="search-empty">
          <div class="search-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
          </div>
          <h3 class="search-empty-title">未找到相关文章</h3>
          <p class="search-empty-desc">没有找到与「<span class="search-query-hl">{query}</span>」相关的内容</p>
          <p class="search-empty-hint">试试换个关键词，或者浏览以下分类</p>
          {siteData.categories.length > 0 && (
            <div class="search-empty-cats">
              {siteData.categories.slice(0, 8).map((cat: any) => (
                <a href={`/topic/${slugToTopicId(cat.slug)}`} class="search-cat-tag">{cat.name}</a>
              ))}
            </div>
          )}
          <a href="/" class="search-empty-btn">返回首页</a>
        </div>
      ) : (
        <div class="search-empty">
          <div class="search-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
          <h3 class="search-empty-title">搜索文章</h3>
          <p class="search-empty-desc">输入关键词搜索全站文章</p>
          {siteData.categories.length > 0 && (
            <div class="search-empty-cats">
              <span class="search-cat-label">热门分类：</span>
              {siteData.categories.slice(0, 8).map((cat: any) => (
                <a href={`/topic/${slugToTopicId(cat.slug)}`} class="search-cat-tag">{cat.name}</a>
              ))}
            </div>
          )}
        </div>
      )}
    </section>
  </main>
</Layout>

<style>
  /* ===== 搜索页布局 ===== */
  .search-page-layout {
    grid-template-columns: 1fr !important;
  }

  .search-content {
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
    padding: 32px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    margin-top: 4px;
  }

  /* ===== 搜索框 ===== */
  .search-bar-wrapper {
    margin-bottom: 24px;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 4px 4px 4px 16px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-bar:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .search-bar-icon {
    flex-shrink: 0;
    color: var(--fg-muted);
    margin-right: 10px;
  }

  .search-bar-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 15px;
    color: var(--fg);
    padding: 10px 0;
    min-width: 0;
  }

  .search-bar-input::placeholder {
    color: var(--fg-muted);
  }

  .search-bar-clear {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }

  .search-bar-clear:hover {
    background: var(--bg-tertiary);
    color: var(--fg);
  }

  .search-bar-btn {
    flex-shrink: 0;
    padding: 8px 20px;
    border-radius: 8px;
    border: none;
    background: var(--accent);
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    margin-left: 4px;
  }

  .search-bar-btn:hover {
    background: var(--accent-hover);
  }

  /* ===== 结果头部 ===== */
  .search-result-header {
    padding: 0 0 16px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }

  .search-result-count {
    font-size: 14px;
    color: var(--fg-secondary);
  }

  .search-result-count strong {
    color: var(--fg);
    font-weight: 600;
  }

  .search-query-hl {
    color: var(--accent);
    font-weight: 500;
  }

  /* ===== 搜索结果列表 ===== */
  .search-result-list {
    display: flex;
    flex-direction: column;
  }

  .search-result-item {
    display: flex;
    gap: 20px;
    padding: 24px;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s, transform 0.2s;
    border-radius: 10px;
    margin: 0 -24px;
  }

  .search-result-item:hover {
    background: var(--bg-tertiary);
    transform: translateX(4px);
  }

  .search-result-item:last-child {
    border-bottom: none;
  }

  .search-result-img {
    flex-shrink: 0;
    width: 180px;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-tertiary);
    display: block;
  }

  .search-result-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .search-result-item:hover .search-result-img img {
    transform: scale(1.05);
  }

  .search-result-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
  }

  .search-result-title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-title a {
    color: var(--fg);
    text-decoration: none;
    transition: color 0.15s;
  }

  .search-result-title a:hover {
    color: var(--accent);
  }

  .search-result-excerpt {
    font-size: 13px;
    color: var(--fg-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 12px;
    color: var(--fg-muted);
  }

  .search-result-cat {
    padding: 2px 10px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .search-result-cat:hover {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .search-result-views {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  /* ===== 空状态 ===== */
  .search-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    text-align: center;
  }

  .search-empty-icon {
    color: var(--fg-muted);
    margin-bottom: 20px;
    opacity: 0.4;
  }

  .search-empty-title {
    font-size: 20px;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 8px;
  }

  .search-empty-desc {
    font-size: 14px;
    color: var(--fg-secondary);
    margin: 0 0 8px;
    line-height: 1.6;
  }

  .search-empty-hint {
    font-size: 13px;
    color: var(--fg-muted);
    margin: 0 0 20px;
  }

  .search-empty-cats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 24px;
    align-items: center;
  }

  .search-cat-label {
    font-size: 13px;
    color: var(--fg-muted);
    margin-right: 4px;
  }

  .search-cat-tag {
    padding: 5px 14px;
    border-radius: 20px;
    background: var(--bg-tertiary);
    color: var(--fg-secondary);
    text-decoration: none;
    font-size: 13px;
    transition: background 0.15s, color 0.15s;
    border: 1px solid var(--border);
  }

  .search-cat-tag:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .search-empty-btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    border-radius: 10px;
    background: var(--accent);
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .search-empty-btn:hover {
    background: var(--accent-hover);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .search-result-item {
      flex-direction: column;
      gap: 12px;
    }

    .search-result-img {
      width: 100%;
    }

    .search-content {
      padding: 16px 0;
    }
  }

  @media (max-width: 480px) {
    .search-bar-btn {
      padding: 8px 14px;
      font-size: 13px;
    }

    .search-empty {
      padding: 40px 20px;
    }
  }
</style>