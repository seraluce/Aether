---
import Layout from "../layouts/Layout.astro";
import PostGrid from "../components/PostGrid.astro";
import { searchPosts } from "../lib/wordpress";
import { mapPost } from "../lib/mappers";
import { siteConfig } from "../site.config";
import { fetchSiteData } from "../data/fetcher";
import { mockData } from "../data/mock";

const query = Astro.url.searchParams.get("q") || "";
const siteFavicon = siteConfig.site.favicon;
const siteLogo = siteConfig.site.logo.light;
const siteIcon = siteConfig.site.logo.light;

const data = await fetchSiteData();
const siteData = data.error ? mockData : data;

let posts: import("../lib/mappers").Post[] = [];
if (query) {
  try {
    const wpPosts = await searchPosts(query);
    posts = wpPosts.map(mapPost);
  } catch {
    posts = [];
  }
}
---

<Layout
  title={query ? `搜索: ${query}` : "搜索"}
  favicon={siteFavicon}
  icon={siteIcon}
  logo={siteLogo}
  categories={siteData.categories}
>
  <main class="main-layout" style="grid-template-columns: 1fr;">
    <section class="content-area" style="max-width: 900px; margin: 0 auto;">
      <div class="content-header">
        <h2 class="content-title">
          {query ? `搜索: ${query}` : "搜索文章"}
        </h2>
        <p style="color: var(--fg-secondary); font-size: 14px; margin-top: 4px;">
          {query ? `找到 ${posts.length} 篇相关文章` : "请输入关键词搜索"}
        </p>
      </div>
      {posts.length > 0 ? (
        <PostGrid posts={posts} />
      ) : query ? (
        <div style="padding: 60px 40px; text-align: center;">
          <p style="color: var(--fg-secondary);">未找到相关文章，换个关键词试试？</p>
          <a href="/" style="display: inline-block; margin-top: 16px; color: var(--accent); font-size: 13px;">返回首页</a>
        </div>
      ) : (
        <div style="padding: 60px 40px; text-align: center;">
          <p style="color: var(--fg-secondary);">请在搜索框输入关键词</p>
        </div>
      )}
    </section>
  </main>
</Layout>
