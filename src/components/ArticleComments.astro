---
interface Props {
  postId: number;
}

const { postId } = Astro.props;
---

<div class="comments-section" id="comments-section">
  <div class="comments-header">
    <div class="comments-header-left">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
      </svg>
      <span>评论</span>
      <span class="comment-count-badge" id="commentCount"></span>
    </div>
  </div>

  <div id="comments-container" class="comments-body">
    <div class="comments-loading" id="commentsLoading">
      <span class="loading-spinner"></span>
      加载评论中...
    </div>
  </div>

  <div class="comment-form-wrapper" id="commentFormWrapper">
    <div class="comment-form-inner">
      <h4 class="comment-form-title">发表评论</h4>
      <form id="commentForm" class="comment-form">
        <input type="hidden" name="post" value={postId} />
        <div class="comment-form-row">
          <input type="text" name="author_name" placeholder="昵称 *" required class="comment-input" />
          <input type="email" name="author_email" placeholder="邮箱（选填）" class="comment-input" />
        </div>
        <textarea name="content" placeholder="写下你的评论..." required class="comment-textarea"></textarea>
        <div class="comment-form-actions">
          <span class="comment-form-hint">支持 Markdown 语法</span>
          <button type="submit" class="comment-submit-btn">提交评论</button>
        </div>
      </form>
      <div class="comment-form-status" id="commentFormStatus"></div>
    </div>
  </div>
</div>

<style>
  .comments-section {
    margin-top: 32px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    overflow: hidden;
    scroll-margin-top: 100px;
  }
  .comments-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
  }
  .comments-header-left {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 17px;
    font-weight: 600;
    color: var(--fg);
  }
  .comments-header-left svg {
    color: var(--accent);
  }
  .comment-count-badge {
    font-size: 13px;
    font-weight: 450;
    color: var(--fg-muted);
    background: var(--bg-tertiary);
    padding: 1px 8px;
    border-radius: 10px;
    line-height: 1.6;
  }

  .comments-body {
    min-height: 60px;
  }

  .comments-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 40px 16px;
    font-size: 14px;
    color: var(--fg-muted);
  }
  .loading-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .comment-item {
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
  }
  .comment-item:last-of-type {
    border-bottom: none;
  }
  .comment-item.depth-1 {
    margin-left: 40px;
    padding: 16px 0 12px;
    border-bottom: none;
    position: relative;
  }
  .comment-item.depth-1::before {
    content: '';
    position: absolute;
    left: -20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
    border-radius: 1px;
  }

  .comment-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .comment-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--bg-tertiary);
    flex-shrink: 0;
    border: 2px solid var(--border);
  }
  .comment-avatar-placeholder {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
  }
  .comment-author {
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
  }
  .comment-date {
    font-size: 12px;
    color: var(--fg-muted);
    margin-left: auto;
  }
  .comment-body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--fg-secondary);
    padding-left: 42px;
  }
  .comment-body p {
    margin: 6px 0;
  }
  .comment-reply-btn {
    font-size: 12px;
    font-weight: 500;
    color: var(--fg-muted);
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px 10px;
    font-family: inherit;
    margin-top: 8px;
    margin-left: 42px;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .comment-reply-btn:hover {
    background: var(--bg-tertiary);
    color: var(--accent);
  }

  .comments-empty {
    padding: 48px 16px;
    text-align: center;
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.8;
  }

  .comment-form-wrapper {
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
  }
  .comment-form-inner {
    padding: 24px;
  }
  .comment-form-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 16px;
  }
  .comment-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .comment-form-row {
    display: flex;
    gap: 12px;
  }
  .comment-input {
    flex: 1;
    padding: 10px 14px;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--fg);
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .comment-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }
  .comment-textarea {
    width: 100%;
    min-height: 100px;
    padding: 10px 14px;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--fg);
    font-family: inherit;
    outline: none;
    resize: vertical;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .comment-textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }
  .comment-form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .comment-form-hint {
    font-size: 12px;
    color: var(--fg-muted);
  }
  .comment-submit-btn {
    padding: 9px 24px;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    background: var(--accent);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, transform 0.1s;
  }
  .comment-submit-btn:hover {
    background: var(--accent-hover);
  }
  .comment-submit-btn:active {
    transform: scale(0.97);
  }
  .comment-submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
  .comment-form-status {
    margin-top: 12px;
    font-size: 13px;
    text-align: center;
    padding: 8px 12px;
    border-radius: 6px;
  }
  .comment-form-status.success {
    color: #16a34a;
    background: #f0fdf4;
  }
  .comment-form-status.error {
    color: #dc2626;
    background: #fef2f2;
  }
  .comment-reply-to {
    font-size: 13px;
    color: var(--fg-muted);
    padding: 8px 14px;
    background: var(--bg-tertiary);
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .comment-reply-to button {
    background: none;
    border: none;
    color: var(--fg-muted);
    cursor: pointer;
    font-size: 16px;
    padding: 0;
    line-height: 1;
    margin-left: auto;
    transition: color 0.15s;
  }
  .comment-reply-to button:hover {
    color: var(--fg);
  }
</style>

<script define:vars={{ postId }}>
  document.addEventListener('DOMContentLoaded', function() {
    var container = document.getElementById('comments-container');
    var loading = document.getElementById('commentsLoading');
    var countEl = document.getElementById('commentCount');
    var form = document.getElementById('commentForm');
    var statusEl = document.getElementById('commentFormStatus');
    var formWrapper = document.getElementById('commentFormWrapper');

    var replyTo = 0;

    function formatDate(dateStr) {
      var d = new Date(dateStr);
      var now = new Date();
      var diff = now.getTime() - d.getTime();
      var days = Math.floor(diff / 86400000);
      if (days === 0) return '今天';
      if (days === 1) return '昨天';
      if (days < 7) return days + '天前';
      return d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
    }

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function renderComments(comments) {
      if (loading) loading.style.display = 'none';

      if (comments.length === 0) {
        container.innerHTML = '<div class="comments-empty">暂无评论，快来抢沙发吧</div>';
        if (countEl) countEl.textContent = '';
        return;
      }

      if (countEl) countEl.textContent = '(' + comments.length + ')';

      var topLevel = comments.filter(function(c) { return c.parent === 0; });
      var byParent = {};
      comments.forEach(function(c) {
        if (c.parent > 0) {
          if (!byParent[c.parent]) byParent[c.parent] = [];
          byParent[c.parent].push(c);
        }
      });

      var html = '';
      topLevel.forEach(function(comment) {
        html += renderComment(comment, 0);
        var replies = byParent[comment.id] || [];
        replies.forEach(function(reply) {
          html += renderComment(reply, 1);
        });
      });

      container.innerHTML = html;

      container.querySelectorAll('.comment-reply-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = parseInt(this.getAttribute('data-comment-id') || '0');
          var name = this.getAttribute('data-author') || '';
          replyTo = id;
          scrollToForm(name);
        });
      });
    }

    function renderComment(comment, depth) {
      var avatar;
      if (comment.author_avatar_urls && comment.author_avatar_urls['48']) {
        avatar = '<img src="' + escapeHtml(comment.author_avatar_urls['48']) + '" alt="" class="comment-avatar" loading="lazy" />';
      } else {
        avatar = '<div class="comment-avatar-placeholder">' + escapeHtml(comment.author_name.charAt(0)) + '</div>';
      }

      return '<div class="comment-item' + (depth > 0 ? ' depth-1' : '') + '">' +
        '<div class="comment-meta">' + avatar +
          '<span class="comment-author">' + escapeHtml(comment.author_name) + '</span>' +
          '<span class="comment-date">' + formatDate(comment.date) + '</span>' +
        '</div>' +
        '<div class="comment-body">' + comment.content.rendered + '</div>' +
        '<button class="comment-reply-btn" data-comment-id="' + comment.id + '" data-author="' + escapeHtml(comment.author_name) + '">回复</button>' +
      '</div>';
    }

    function scrollToForm(replyName) {
      var textarea = form && form.querySelector('textarea');
      var existing = formWrapper && formWrapper.querySelector('.comment-reply-to');
      if (existing) existing.remove();

      if (replyName) {
        var bar = document.createElement('div');
        bar.className = 'comment-reply-to';
        bar.innerHTML = '回复 @' + escapeHtml(replyName) + '<button type="button" id="cancelReply">&times;</button>';
        if (form) form.insertBefore(bar, form.firstChild);
        bar.querySelector('#cancelReply').addEventListener('click', function() {
          replyTo = 0;
          bar.remove();
        });
      }

      if (formWrapper) formWrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });
      if (textarea) textarea.focus();
    }

    fetch('/api/comments?postId=' + postId)
      .then(function(res) { return res.json(); })
      .then(function(comments) {
        if (Array.isArray(comments)) {
          renderComments(comments);
        } else {
          if (loading) loading.textContent = '评论加载失败';
        }
      })
      .catch(function() {
        if (loading) loading.textContent = '评论加载失败';
      });

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('.comment-submit-btn');
        btn.disabled = true;
        btn.textContent = '提交中...';
        statusEl.className = 'comment-form-status';
        statusEl.textContent = '';

        var data = {
          post: postId,
          author_name: form.querySelector('[name="author_name"]').value,
          author_email: form.querySelector('[name="author_email"]').value,
          content: form.querySelector('[name="content"]').value,
        };
        if (replyTo > 0) data.parent = replyTo;

        fetch('/api/comments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })
          .then(function(res) { return res.json(); })
          .then(function(result) {
            if (result.success) {
              statusEl.className = 'comment-form-status success';
              statusEl.textContent = '评论提交成功，等待审核后显示';
              form.reset();
              replyTo = 0;
              var bar = formWrapper && formWrapper.querySelector('.comment-reply-to');
              if (bar) bar.remove();
            } else {
              statusEl.className = 'comment-form-status error';
              statusEl.textContent = result.error || '提交失败，请稍后再试';
            }
          })
          .catch(function() {
            statusEl.className = 'comment-form-status error';
            statusEl.textContent = '网络错误，请稍后再试';
          })
          .finally(function() {
            btn.disabled = false;
            btn.textContent = '提交评论';
          });
      });
    }
  });
</script>
