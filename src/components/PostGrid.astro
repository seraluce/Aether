---
import type { Post } from '../lib/mappers';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}月${d.getDate()}日`;
}

function formatViews(n: number): string {
  return n >= 10000 ? (n / 10000).toFixed(1) + '万' : n.toString();
}

const sortedByDate = [...posts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const sortedByViews = [...posts].sort((a, b) => b.views - a.views);
const recommended = posts.filter((_, i) => i % 2 === 0);
---

<div class="content-header">
  <h2 class="content-title">最新资讯</h2>
  <div class="content-tabs" id="contentTabs">
    <a href="#" class="active" data-tab="latest">最新</a>
    <a href="#" data-tab="hot">热门</a>
    <a href="#" data-tab="recommended">推荐</a>
  </div>
</div>

<div class="post-grid" id="postGrid">
  {sortedByDate.map((post, index) => (
    <article class={`post-card lazy-card ${index === 0 ? 'post-featured' : ''}`} data-tab="latest" data-index={index} style={index >= 12 ? 'display:none;' : ''}>
      {post.image && (
      <div class="post-card-image-wrapper">
        <img class="post-card-image" src={post.image} alt={post.title} loading="lazy"
          onload="this.classList.add('loaded');this.parentElement.classList.add('loaded')" />
      </div>
      )}
      <div class="post-card-body">
        <a href={`/category/${post.categorySlug}`} class="post-card-category">{post.category}</a>
        <h3 class="post-card-title"><a href={`/post/${post.id}`}>{post.title}</a></h3>
        <p class="post-card-excerpt">{post.excerpt}</p>
        <div class="post-card-meta">
          <div class="meta-left">
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              {post.author}
            </span>
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {formatDate(post.date)}
            </span>
          </div>
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            {formatViews(post.views)}
          </span>
        </div>
      </div>
    </article>
  ))}

  {sortedByViews.map((post, index) => (
    <article class={`post-card lazy-card ${index === 0 ? 'post-featured' : ''}`} data-tab="hot" data-index={index} style={index >= 12 ? 'display:none;' : ''}>
      {post.image && (
      <div class="post-card-image-wrapper">
        <img class="post-card-image" src={post.image} alt={post.title} loading="lazy"
          onload="this.classList.add('loaded');this.parentElement.classList.add('loaded')" />
      </div>
      )}
      <div class="post-card-body">
        <a href={`/category/${post.categorySlug}`} class="post-card-category">{post.category}</a>
        <h3 class="post-card-title"><a href={`/post/${post.id}`}>{post.title}</a></h3>
        <p class="post-card-excerpt">{post.excerpt}</p>
        <div class="post-card-meta">
          <div class="meta-left">
            <span>{post.author}</span>
            <span>{formatDate(post.date)}</span>
          </div>
          <span>{formatViews(post.views)} 阅读</span>
        </div>
      </div>
    </article>
  ))}

  {recommended.map((post, index) => (
    <article class={`post-card lazy-card ${index === 0 ? 'post-featured' : ''}`} data-tab="recommended" data-index={index} style={index >= 12 ? 'display:none;' : ''}>
      {post.image && (
      <div class="post-card-image-wrapper">
        <img class="post-card-image" src={post.image} alt={post.title} loading="lazy"
          onload="this.classList.add('loaded');this.parentElement.classList.add('loaded')" />
      </div>
      )}
      <div class="post-card-body">
        <a href={`/category/${post.categorySlug}`} class="post-card-category">{post.category}</a>
        <h3 class="post-card-title"><a href={`/post/${post.id}`}>{post.title}</a></h3>
        <p class="post-card-excerpt">{post.excerpt}</p>
        <div class="post-card-meta">
          <div class="meta-left">
            <span>{post.author}</span>
            <span>{formatDate(post.date)}</span>
          </div>
          <span>{formatViews(post.views)} 阅读</span>
        </div>
      </div>
    </article>
  ))}
</div>

<div class="load-more-sentinel" id="loadMoreSentinel">
  <div class="load-more-indicator" id="loadMoreIndicator" style="display:none;">
    <span class="loading-spinner"></span>
    加载更多...
  </div>
  <div class="load-more-end" id="loadMoreEnd" style="display:none;">
    已经到底了
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var BATCH = 12;
    var tabs = document.querySelectorAll('#contentTabs a');
    var grid = document.getElementById('postGrid');
    var sentinel = document.getElementById('loadMoreSentinel');
    var indicator = document.getElementById('loadMoreIndicator');
    var endMsg = document.getElementById('loadMoreEnd');

    var revealed = { latest: BATCH, hot: BATCH, recommended: BATCH };
    var currentTab = 'latest';
    var loading = false;

    function getVisibleCards() {
      return grid.querySelectorAll('.post-card[data-tab="' + currentTab + '"]');
    }

    function getTotal(tab) {
      return grid.querySelectorAll('.post-card[data-tab="' + tab + '"]').length;
    }

    function updateSentinel() {
      var total = getTotal(currentTab);
      if (revealed[currentTab] >= total) {
        indicator.style.display = 'none';
        endMsg.style.display = total > BATCH ? '' : 'none';
      } else {
        indicator.style.display = 'none';
        endMsg.style.display = 'none';
      }
    }

    function revealMore() {
      if (loading) return;
      var total = getTotal(currentTab);
      if (revealed[currentTab] >= total) {
        updateSentinel();
        return;
      }

      loading = true;
      indicator.style.display = '';

      var cards = getVisibleCards();
      var start = revealed[currentTab];
      var end = Math.min(start + BATCH, total);

      setTimeout(function() {
        for (var i = start; i < end; i++) {
          if (cards[i]) {
            cards[i].style.display = '';
            var imgs = cards[i].querySelectorAll('img[loading="lazy"]');
            imgs.forEach(function(img) {
              if (img.dataset.src) {
                img.src = img.dataset.src;
              }
            });
          }
        }
        revealed[currentTab] = end;
        loading = false;
        indicator.style.display = 'none';
        updateSentinel();
      }, 300);
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function(e) {
        e.preventDefault();
        var target = this.getAttribute('data-tab');
        if (target === currentTab) return;

        tabs.forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');

        var oldCards = grid.querySelectorAll('.post-card[data-tab="' + currentTab + '"]');
        oldCards.forEach(function(c) { c.style.display = 'none'; });

        currentTab = target;
        endMsg.style.display = 'none';
        indicator.style.display = 'none';

        var newCards = getVisibleCards();
        newCards.forEach(function(c, i) {
          c.style.display = i < revealed[currentTab] ? '' : 'none';
        });
        updateSentinel();
      });
    });

    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        revealMore();
      }
    }, { rootMargin: '200px' });

    observer.observe(sentinel);
    updateSentinel();
  });
</script>
