---
import type { Post } from "../lib/mappers";
import { slugToTopicId, postToArticleId } from "../lib/route-ids";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}月${d.getDate()}日`;
}

function formatViews(n: number): string {
  return n >= 10000 ? (n / 10000).toFixed(1) + "万" : n.toString();
}

const sortedByDate = [...posts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
const sortedByViews = [...posts].sort((a, b) => b.views - a.views);
const recommended = posts.filter((_, i) => i % 2 === 0);
---

<div class="content-header">
  <h2 class="content-title">最新资讯</h2>
  <div class="content-tabs" id="contentTabs">
    <a href="#" class="active" data-tab="latest">最新</a>
    <a href="#" data-tab="hot">热门</a>
    <a href="#" data-tab="recommended">推荐</a>
  </div>
</div>

<div class="post-list" id="postGrid">
  {
    sortedByDate.map((post, index) => (
      <article
        class="post-item"
        data-tab="latest"
        data-index={index}
        style={index >= 12 ? "display:none;" : ""}
      >
        {post.image && (
          <a href={`/article/${postToArticleId(post.id)}`} class="post-item-image-link">
            <img
              class="post-item-image"
              src={post.image}
              alt={post.title}
              loading="lazy"
              width="192"
              height="108"
            />
          </a>
        )}
        <div class="post-item-content">
          <h3 class="post-item-title">
            <a href={`/article/${postToArticleId(post.id)}`}>{post.title}</a>
          </h3>
          <p class="post-item-excerpt">{post.excerpt}</p>
          <div class="post-item-meta">
            <a
              href={`/topic/${slugToTopicId(post.categorySlug)}`}
              class="post-item-category"
            >
              {post.category}
            </a>
            <div class="meta-right">
              <span class="post-item-views">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                    <circle cx="12" cy="12" r="3" />
                  </>
                </svg>
                {formatViews(post.views)}
              </span>
              <span>
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </>
                </svg>
                {formatDate(post.date)}
              </span>
            </div>
          </div>
        </div>
      </article>
    ))
  }

  {
    sortedByViews.map((post, index) => (
      <article
        class="post-item"
        data-tab="hot"
        data-index={index}
        style="display:none;"
      >
        {post.image && (
          <a href={`/article/${postToArticleId(post.id)}`} class="post-item-image-link">
            <img
              class="post-item-image"
              src={post.image}
              alt={post.title}
              loading="lazy"
              width="192"
              height="108"
            />
          </a>
        )}
        <div class="post-item-content">
          <h3 class="post-item-title">
            <a href={`/article/${postToArticleId(post.id)}`}>{post.title}</a>
          </h3>
          <p class="post-item-excerpt">{post.excerpt}</p>
          <div class="post-item-meta">
            <a
              href={`/topic/${slugToTopicId(post.categorySlug)}`}
              class="post-item-category"
            >
              {post.category}
            </a>
            <div class="meta-right">
              <span class="post-item-views">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                    <circle cx="12" cy="12" r="3" />
                  </>
                </svg>
                {formatViews(post.views)}
              </span>
              <span>{post.author}</span>
              <span>{formatDate(post.date)}</span>
            </div>
          </div>
        </div>
      </article>
    ))
  }

  {
    recommended.map((post, index) => (
      <article
        class="post-item"
        data-tab="recommended"
        data-index={index}
        style="display:none;"
      >
        {post.image && (
          <a href={`/article/${postToArticleId(post.id)}`} class="post-item-image-link">
            <img
              class="post-item-image"
              src={post.image}
              alt={post.title}
              loading="lazy"
              width="192"
              height="108"
            />
          </a>
        )}
        <div class="post-item-content">
          <h3 class="post-item-title">
            <a href={`/article/${postToArticleId(post.id)}`}>{post.title}</a>
          </h3>
          <p class="post-item-excerpt">{post.excerpt}</p>
          <div class="post-item-meta">
            <a
              href={`/topic/${slugToTopicId(post.categorySlug)}`}
              class="post-item-category"
            >
              {post.category}
            </a>
            <div class="meta-right">
              <span class="post-item-views">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                    <circle cx="12" cy="12" r="3" />
                  </>
                </svg>
                {formatViews(post.views)}
              </span>
              <span>{post.author}</span>
              <span>{formatDate(post.date)}</span>
            </div>
          </div>
        </div>
      </article>
    ))
  }
</div>

<div class="load-more-sentinel" id="loadMoreSentinel">
  <div class="load-more-indicator" id="loadMoreIndicator" style="display:none;">
    <span class="loading-spinner"></span>
    加载更多...
  </div>
  <div class="load-more-end" id="loadMoreEnd" style="display:none;">
    已经到底了
  </div>
</div>

<style>
/* ===== 图片容器 + 骨架屏 ===== */
.post-item-image-link {
  flex-shrink: 0;
  width: 192px;
  aspect-ratio: 16 / 9;
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-tertiary);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  display: block;
  position: relative;
}

/* ===== shimmer 动画 ===== */
@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* ===== 图片样式 ===== */
.post-item-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0;
  transition: opacity 0.4s ease;
}

/* ===== 图片加载完成 ===== */
.post-item-image.loaded {
  opacity: 1;
}

.post-item-image-link.loaded {
  animation: none;
  background: transparent;
}

/* ===== 图片加载失败时，保持骨架屏 ===== */
/* 无需额外样式，因为 error 时不会添加 loaded 类 */

/* ===== 可选：错误状态占位文字 ===== */
.post-item-image-link.error::after {
  content: '图片无法加载';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: var(--fg-muted);
  background: var(--bg-tertiary);
  border-radius: 8px;
  z-index: 1;
}

@media (max-width: 768px) {
  .post-item-image-link {
    width: 110px;
    aspect-ratio: 16 / 9;
  }
  .post-item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
}

/* ===== 其他已有样式 ===== */
/* 保留您原有的其他样式 */
</style>

<script>
  // ===== 图片加载处理 =====
  function handleImageLoading(): void {
    const images = document.querySelectorAll('.post-item-image');
    images.forEach((img) => {
      const imageElement = img as HTMLImageElement;
      const link = img.closest('.post-item-image-link') as HTMLAnchorElement | null;
      
      // 移除可能存在的内联 onload
      imageElement.removeAttribute('onload');
      
      // 如果图片已经加载完成（缓存），立即显示
      if (imageElement.complete && imageElement.naturalWidth > 0) {
        imageElement.classList.add('loaded');
        if (link) link.classList.add('loaded');
        return;
      }
      
      // 加载成功 → 显示图片
      imageElement.addEventListener('load', () => {
        imageElement.classList.add('loaded');
        if (link) link.classList.add('loaded');
      });
      
      // 加载失败 → 保持骨架屏动画（不添加 loaded 类）
      imageElement.addEventListener('error', () => {
        // 可选：在控制台记录失败图片
        console.warn('[图片加载失败]', imageElement.src);
        
        // 可选：显示错误占位（需要 CSS 配合）
        // if (link) link.classList.add('error');
      });
    });
  }

  // ===== DOM 就绪后初始化 =====
  document.addEventListener('DOMContentLoaded', function () {
    // 初始处理所有图片
    handleImageLoading();

    const BATCH = 12;
    const tabs = document.querySelectorAll('#contentTabs a');
    const grid = document.getElementById('postGrid') as HTMLElement;
    const sentinel = document.getElementById('loadMoreSentinel') as HTMLElement;
    const indicator = document.getElementById('loadMoreIndicator') as HTMLElement;
    const endMsg = document.getElementById('loadMoreEnd') as HTMLElement;

    const revealed: Record<string, number> = {
      latest: BATCH,
      hot: BATCH,
      recommended: BATCH,
    };
    let currentTab = 'latest';
    let loading = false;

    function getVisibleItems(): NodeListOf<HTMLElement> {
      return grid.querySelectorAll(`.post-item[data-tab="${currentTab}"]`);
    }

    function getTotal(tab: string): number {
      return grid.querySelectorAll(`.post-item[data-tab="${tab}"]`).length;
    }

    function updateSentinel(): void {
      const total = getTotal(currentTab);
      if (revealed[currentTab] >= total) {
        indicator.style.display = 'none';
        endMsg.style.display = total > BATCH ? '' : 'none';
      } else {
        indicator.style.display = 'none';
        endMsg.style.display = 'none';
      }
    }

    function revealMore(): void {
      if (loading) return;
      const total = getTotal(currentTab);
      if (revealed[currentTab] >= total) {
        updateSentinel();
        return;
      }

      loading = true;
      indicator.style.display = '';

      const items = getVisibleItems();
      const start = revealed[currentTab];
      const end = Math.min(start + BATCH, total);

      requestAnimationFrame(() => {
        for (let i = start; i < end; i++) {
          if (items[i]) {
            items[i].style.display = '';
          }
        }
        revealed[currentTab] = end;
        loading = false;
        indicator.style.display = 'none';
        updateSentinel();
        
        // 新显示的图片需要重新检查加载状态
        handleImageLoading();
      });
    }

    // ===== Tab 切换 =====
    tabs.forEach((tab) => {
      tab.addEventListener('click', function (this: HTMLAnchorElement, e: MouseEvent) {
        e.preventDefault();
        const target = this.getAttribute('data-tab');
        if (!target || target === currentTab) return;

        tabs.forEach((t) => t.classList.remove('active'));
        this.classList.add('active');

        // 隐藏当前 Tab
        const oldItems = grid.querySelectorAll(
          `.post-item[data-tab="${currentTab}"]`,
        );
        oldItems.forEach((item) => {
          (item as HTMLElement).style.display = 'none';
        });

        currentTab = target;
        endMsg.style.display = 'none';
        indicator.style.display = 'none';

        // 显示新 Tab
        const newItems = getVisibleItems();
        newItems.forEach((item, i) => {
          item.style.display = i < revealed[currentTab] ? '' : 'none';
        });

        updateSentinel();
        handleImageLoading();
      });
    });

    // ===== 无限滚动 =====
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          revealMore();
        }
      },
      { rootMargin: '200px' },
    );

    observer.observe(sentinel);
    updateSentinel();
  });
</script>