---
import type { Post } from "../lib/mappers";
import { slugToTopicId, postToArticleId } from "../lib/route-ids";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}月${d.getDate()}日`;
}

function formatViews(n: number): string {
  return n >= 10000 ? (n / 10000).toFixed(1) + "万" : n.toString();
}
---

<div class="content-header">
  <h2 class="content-title">最新资讯</h2>
  <div class="content-tabs" id="contentTabs">
    <a href="#" class="active" data-tab="latest">最新</a>
    <a href="#" data-tab="hot">热门</a>
    <a href="#" data-tab="recommended">推荐</a>
  </div>
</div>

<div class="post-list" id="postGrid" data-posts={JSON.stringify(posts)}>
</div>

<div class="load-more-sentinel" id="loadMoreSentinel">
  <div class="load-more-indicator" id="loadMoreIndicator" style="display:none;">
    <span class="loading-spinner"></span>
    加载更多...
  </div>
  <div class="load-more-end" id="loadMoreEnd" style="display:none;">
    已经到底了
  </div>
</div>

<style>
.post-item-image-link {
  flex-shrink: 0;
  width: 192px;
  aspect-ratio: 16 / 9;
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-tertiary);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  display: block;
  position: relative;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.post-item-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.post-item-image.loaded {
  opacity: 1;
}

.post-item-image-link.loaded {
  animation: none;
  background: transparent;
}

.post-item-image-link.error::after {
  content: '图片无法加载';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: var(--fg-muted);
  background: var(--bg-tertiary);
  border-radius: 8px;
  z-index: 1;
}

@media (max-width: 768px) {
  .content-area{
    top: 0;
    border-radius: 0;
  }
  .post-item-image-link {
    width: 110px;
    aspect-ratio: 16 / 9;
  }
  .post-item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
}
</style>

<script>
  // @ts-nocheck
  function slugToTopicId(slug) {
    var hash = 5381;
    for (var i = 0; i < slug.length; i++) hash = ((hash << 5) + hash) + slug.charCodeAt(i);
    return String((hash >>> 0) % 90000000 + 10000000);
  }

  function postToArticleId(id) {
    var str = String(id);
    var hash = 5381;
    for (var i = 0; i < str.length; i++) hash = ((hash << 5) + hash) + str.charCodeAt(i);
    return String((hash >>> 0) % 900000000000 + 100000000000);
  }

  function formatDate(dateStr) {
    var d = new Date(dateStr);
    return (d.getMonth() + 1) + '月' + d.getDate() + '日';
  }

  function formatViews(n) {
    return n >= 10000 ? (n / 10000).toFixed(1) + '万' : String(n);
  }

  function renderPostItem(post, index, tab, hidden) {
    var imageHtml = post.image
      ? '<a href="/article/' + postToArticleId(post.id) + '" class="post-item-image-link">' +
        '<img class="post-item-image" src="' + post.image + '" alt="' + post.title + '" loading="lazy" width="192" height="108" />' +
        '</a>'
      : '';
    return '<article class="post-item" data-tab="' + tab + '" data-index="' + index + '"' + (hidden ? ' style="display:none;"' : '') + '>' +
      imageHtml +
      '<div class="post-item-content">' +
        '<h3 class="post-item-title"><a href="/article/' + postToArticleId(post.id) + '">' + post.title + '</a></h3>' +
        '<p class="post-item-excerpt">' + post.excerpt + '</p>' +
        '<div class="post-item-meta">' +
          '<a href="/topic/' + slugToTopicId(post.categorySlug) + '" class="post-item-category">' + post.category + '</a>' +
          '<div class="meta-right">' +
            '<span class="post-item-views">' +
              '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> ' +
              formatViews(post.views) +
            '</span>' +
            '<span>' + post.author + '</span>' +
            '<span>' + formatDate(post.date) + '</span>' +
          '</div>' +
        '</div>' +
      '</div>' +
    '</article>';
  }

  document.addEventListener('DOMContentLoaded', function () {
    var grid = document.getElementById('postGrid');
    var posts = JSON.parse(grid.dataset.posts || '[]');
    var BATCH = 12;
    var tabs = document.querySelectorAll('#contentTabs a');
    var sentinel = document.getElementById('loadMoreSentinel');
    var indicator = document.getElementById('loadMoreIndicator');
    var endMsg = document.getElementById('loadMoreEnd');

    var sortedByDate = posts.slice().sort(function(a, b) { return new Date(b.date) - new Date(a.date); });
    var sortedByViews = posts.slice().sort(function(a, b) { return b.views - a.views; });
    var recommended = posts.filter(function(_, i) { return i % 2 === 0; });

    var allHtml = '';
    sortedByDate.forEach(function(p, i) { allHtml += renderPostItem(p, i, 'latest', i >= BATCH); });
    sortedByViews.forEach(function(p, i) { allHtml += renderPostItem(p, i, 'hot', true); });
    recommended.forEach(function(p, i) { allHtml += renderPostItem(p, i, 'recommended', true); });
    grid.innerHTML = allHtml;

    function handleImageLoading() {
      grid.querySelectorAll('.post-item-image').forEach(function(img) {
        var imageElement = img;
        var link = img.closest('.post-item-image-link');
        if (imageElement.complete && imageElement.naturalWidth > 0) {
          imageElement.classList.add('loaded');
          if (link) link.classList.add('loaded');
          return;
        }
        imageElement.addEventListener('load', function() {
          imageElement.classList.add('loaded');
          if (link) link.classList.add('loaded');
        });
      });
    }

    handleImageLoading();

    var revealed = { latest: BATCH, hot: BATCH, recommended: BATCH };
    var currentTab = 'latest';
    var loading = false;

    function getVisibleItems() {
      return grid.querySelectorAll('.post-item[data-tab="' + currentTab + '"]');
    }

    function getTotal(tab) {
      return grid.querySelectorAll('.post-item[data-tab="' + tab + '"]').length;
    }

    function updateSentinel() {
      var total = getTotal(currentTab);
      if (revealed[currentTab] >= total) {
        indicator.style.display = 'none';
        endMsg.style.display = total > BATCH ? '' : 'none';
      } else {
        indicator.style.display = 'none';
        endMsg.style.display = 'none';
      }
    }

    function revealMore() {
      if (loading) return;
      var total = getTotal(currentTab);
      if (revealed[currentTab] >= total) { updateSentinel(); return; }
      loading = true;
      indicator.style.display = '';
      var items = getVisibleItems();
      var start = revealed[currentTab];
      var end = Math.min(start + BATCH, total);
      requestAnimationFrame(function() {
        for (var i = start; i < end; i++) {
          if (items[i]) items[i].style.display = '';
        }
        revealed[currentTab] = end;
        loading = false;
        indicator.style.display = 'none';
        updateSentinel();
        handleImageLoading();
      });
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function(e) {
        e.preventDefault();
        var target = this.getAttribute('data-tab');
        if (!target || target === currentTab) return;
        tabs.forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');
        var oldItems = grid.querySelectorAll('.post-item[data-tab="' + currentTab + '"]');
        oldItems.forEach(function(item) { item.style.display = 'none'; });
        currentTab = target;
        endMsg.style.display = 'none';
        indicator.style.display = 'none';
        var newItems = getVisibleItems();
        newItems.forEach(function(item, i) {
          item.style.display = i < revealed[currentTab] ? '' : 'none';
        });
        updateSentinel();
        handleImageLoading();
      });
    });

    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) revealMore();
    }, { rootMargin: '200px' });

    observer.observe(sentinel);
    updateSentinel();
  });
</script>
