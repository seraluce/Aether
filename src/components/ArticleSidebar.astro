---
import { postToArticleId } from '../lib/route-ids';
import { siteConfig } from '../site.config';

interface Props {
  relatedPosts: Array<{ id: number; title: string; image: string }>;
  postId: number;
}

const { relatedPosts, postId } = Astro.props;
const { about } = siteConfig;

---

<div class="sidebar-inner">
  <div class="sidebar-card author-card">
    <div class="author-avatar">
      <img src={about.avatar} alt={siteConfig.site.name} width="56" height="56" />
    </div>
    <div class="author-name">{siteConfig.site.name}</div>
    <div class="author-bio">{about.bio}</div>
    <div class="author-social">
      {about.social.filter(s => s.url).map(s => {
        const icon = s.icon;
        return (
        <a href={s.url} class="social-link" target="_blank" rel="noopener noreferrer" title={s.name}>
          {icon === 'github' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>}
          {icon === 'x' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"/></svg>}
          {icon === 'gmail' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/></svg>}
          {icon === 'bilibili' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/></svg>}
          {icon === 'tiktok' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>}
        </a>
        );
      })}
    </div>
  </div>

  <div class="sidebar-card">
    <div class="sidebar-card-title">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      相关推荐
    </div>
    <div style="padding: 4px 0;">
      {relatedPosts.map((post) => (
        <a href={`/article/${postToArticleId(post.id)}`} class="related-item">
          {post.image && <img src={post.image} alt="" />}
          <span>{post.title}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .author-card {
    text-align: center;
    padding: 28px 24px 24px;
  }
  .author-avatar {
    margin-bottom: 14px;
  }
  .author-avatar img {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    background: var(--bg-tertiary);
  }
  .author-name {
    font-size: 16px;
    font-weight: 650;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }
  .author-bio {
    font-size: 12px;
    line-height: 1.5;
    color: var(--fg-muted);
    margin-bottom: 16px;
    max-width: 200px;
    margin-left: auto;
    margin-right: auto;
  }
  .author-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--fg-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    transition: all 0.15s;
  }
  .social-link:hover {
    color: var(--accent);
    background: var(--accent-bg);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .social-link svg {
    width: 16px;
    height: 16px;
  }

  .related-item {
    display: flex;
    gap: 10px;
    padding: 8px 16px;
    transition: background 0.1s ease;
    text-decoration: none;
    border-radius: 6px;
  }
  .related-item:hover {
    background: var(--bg-tertiary);
  }
  .related-item img {
    width: 56px;
    height: 42px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .related-item span {
    font-size: 13px;
    font-weight: 450;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--fg-secondary);
  }
  .related-item:hover span {
    color: var(--accent);
  }
</style>
