---
import { siteConfig } from "../site.config";

interface Props {
  categories: Array<{ name: string; slug: string; count: number; icon: string }>;
}

const { categories = [] } = Astro.props;
---

<div class="sidebar-card">
  <div class="sidebar-card-title"> <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"> <path d="M4 6h16M4 12h16M4 18h16"></path> </svg>
分类
</div>
  <ul class="category-list">
    {categories.map((cat) => (
      <li>
        <a href={`/topic/${cat.slug}`}>
          <span class="cat-icon" set:html={cat.icon}></span>
          <span class="cat-name">{cat.name}</span>
          <span class="cat-count">{cat.count}</span>
        </a>
      </li>
    ))}
  </ul>
</div>
