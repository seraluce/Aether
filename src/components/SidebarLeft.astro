---
interface Props {
  categories: Array<{ name: string; slug: string; count: number; icon: string }>;
}

const { categories } = Astro.props;
---

<div class="sidebar-card">
  <div class="sidebar-card-title">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
    分类
  </div>
  <ul class="category-list">
    {categories.map((cat) => (
      <li>
        <a href={`/category/${cat.slug}`}>
          <span class="cat-icon">{cat.icon}</span>
          <span class="cat-name">{cat.name}</span>
          <span class="cat-count">{cat.count}</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<div class="sidebar-card">
  <div class="sidebar-card-title">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 9h18M9 21V9"/>
    </svg>
    统计
  </div>
  <div class="stats-widget">
    <div class="stat-item">
      <div class="number">{categories.reduce((sum, c) => sum + c.count, 0).toLocaleString()}</div>
      <div class="label">文章</div>
    </div>
    <div class="stat-item">
      <div class="number">368</div>
      <div class="label">今日</div>
    </div>
    <div class="stat-item">
      <div class="number">52.4k</div>
      <div class="label">访问</div>
    </div>
    <div class="stat-item">
      <div class="number">8.7k</div>
      <div class="label">评论</div>
    </div>
  </div>
</div>
