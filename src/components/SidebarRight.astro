---
import type { Post } from '../lib/mappers';
import { siteConfig } from '../site.config';

interface Props {
  hotPosts: Post[];
  tags: string[];
}

const { hotPosts = [], tags = [] } = Astro.props as Props;
const tagsLimit = siteConfig.widgets.tagsCount || 10;
const visibleTags = tags.slice(0, tagsLimit);
const hasMoreTags = tags.length > tagsLimit;

function formatViews(n: number): string {
  return n >= 10000 ? (n / 10000).toFixed(1) + '万' : n.toString();
}
---

<div class="sidebar-card">
  <div class="sidebar-card-title">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    搜索
  </div>
  <div class="search-widget">
    <form action="/search" method="get">
      <input type="text" name="q" placeholder="输入关键词..." />
      <button type="submit">搜索</button>
    </form>
  </div>
</div>

<div class="sidebar-card">
  <div class="sidebar-card-title">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
    </svg>
    热门文章
  </div>
  <div class="hot-post-list">
    {hotPosts.map((post, index) => (
      <div class="hot-post-item">
        <span class={`hot-post-rank ${index < 3 ? 'top' : ''}`}>{index + 1}</span>
        <div class="hot-post-info">
          <h4><a href={`/post/${post.id}`}>{post.title}</a></h4>
          <span class="views">{formatViews(post.views)} 阅读</span>
        </div>
      </div>
    ))}
  </div>
</div>

<div class="sidebar-card">
  <div class="sidebar-card-title">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
      <line x1="7" y1="7" x2="7.01" y2="7"/>
    </svg>
    标签
    {hasMoreTags && (
      <a href="/tags" class="sidebar-card-more">
        更多
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    )}
  </div>
  <div class="tag-cloud">
    {visibleTags.map((tag) => (
      <a href={`/tag/${tag}`}>{tag}</a>
    ))}
  </div>
</div>

<div class="sidebar-card">
  <div class="footer-widget">
    <div class="footer-widget-row">
      <a href="/archive">归档</a>
      <span class="footer-dot">·</span>
      <a href="/about">关于</a>
      <span class="footer-dot">·</span>
      <a href="/sitemap.xml">Sitemap</a>
    </div>
    <div class="footer-widget-row">
      <span>资讯新闻</span>
      <span class="footer-dot">·</span>
      <span>&copy; 2026 All rights reserved.</span>
    </div>
    <div class="footer-widget-row">
      <a href="https://beian.miit.gov.cn/" target="_blank" rel="nofollow noopener">京ICP备XXXXXXXX号</a>
    </div>
    <div class="footer-widget-powered">Powered by Astro + WordPress</div>
  </div>
</div>
