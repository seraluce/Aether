---
// src/components/LoadMore.astro
---

<button id="load-more" class="load-more-btn">
  加载更多文章
  <span class="loading-spinner" style="display:none;">⏳</span>
</button>

<script>
  let currentPage = 1;
  const loadMoreBtn = document.getElementById('load-more');
  const spinner = loadMoreBtn.querySelector('.loading-spinner');

  loadMoreBtn.addEventListener('click', async () => {
    // 显示加载状态
    loadMoreBtn.disabled = true;
    spinner.style.display = 'inline';

    try {
      currentPage++;
      const response = await fetch(`/api/posts.json?page=${currentPage}`);
      const posts = await response.json();

      if (posts.length === 0) {
        loadMoreBtn.textContent = '没有更多文章了';
        loadMoreBtn.disabled = true;
        return;
      }

      // 追加文章到列表
      appendPosts(posts);
      
    } catch (error) {
      console.error('加载更多失败:', error);
      loadMoreBtn.textContent = '加载失败，点击重试';
    } finally {
      loadMoreBtn.disabled = false;
      spinner.style.display = 'none';
    }
  });

  function appendPosts(posts) {
    const postGrid = document.querySelector('.post-grid');
    const newHTML = posts.map(post => `
      <article class="post-card" data-post-id="${post.id}">
        <h2><a href="/post/${post.id}">${post.title.rendered}</a></h2>
        <div class="post-excerpt">${post.excerpt?.rendered || ''}</div>
        <div class="post-meta">
          <span>${new Date(post.date).toLocaleDateString('zh-CN')}</span>
        </div>
      </article>
    `).join('');

    postGrid.insertAdjacentHTML('beforeend', newHTML);
  }
</script>

<style>
  .load-more-btn {
    display: block;
    width: 100%;
    padding: 12px;
    margin: 20px 0;
    background: #007bff;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 16px;
    transition: background 0.2s;
  }
  .load-more-btn:hover:not(:disabled) {
    background: #0056b3;
  }
  .load-more-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .loading-spinner {
    margin-left: 8px;
  }
</style>